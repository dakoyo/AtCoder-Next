{
  "name": "atcoder-next",
  "version": "1.3.1",
  "description": "AtCoder Next CLI (Local-first)",
  "main": "dist/cli.js",
  "bin": {
    "atc": "./dist/cli.js"
  },
  "type": "commonjs",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "tsx src/cli.ts",
