  "dependencies": {
    "@clack/prompts": "^0.7.0",
    "axios": "^1.6.8",
    "cheerio": "^1.0.0-rc.12",
    "commander": "^12.0.0",
    "esbuild": "^0.28.1",
    "ora": "^5.4.1",
    "picocolors": "^1.0.0",
    "playwright-core": "^1.61.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.24",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3",
    "vitest": "^1.3.1"
  }
